# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Remove www from URL (optional)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ http://%1/$1 [R=301,L]
    
    # City Guides: /guide/city/{city-slug}
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^guide/city/([a-z0-9-]+)/?$ /pages/city-guide.php?city=$1 [QSA,L]

    # Category Guides: /guide/category/{category-slug}
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^guide/category/([a-z0-9-]+)/?$ /pages/category-guide.php?cat=$1 [QSA,L]

    # Keyword Variation Pages: /kw/{type}/{category}/{city}
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^kw/(best|top|affordable|near-me|cheap|services)/([a-z0-9-]+)/([a-z0-9-]+)/?$ /pages/keyword-variations.php?type=$1&category=$2&city=$3 [QSA,L]

    # SEO Pages: /best-{category}-in-{city}, /affordable-{category}-{city}, etc.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(best|top|affordable)-(.+)-in-(.+)/?$ /pages/seo-page.php?type=$1&category=$2&city=$3 [QSA,L]

    # Category-City routing: /category/{category-slug}/{city-slug}
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^category/([a-z0-9-]+)/([a-z0-9-]+)/?$ /pages/category-city.php?category=$1&city=$2 [QSA,L]

    # Business profile: /business/{id}-{slug}
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^business/([0-9]+)-([a-z0-9-]+)/?$ /pages/business-detail.php?id=$1 [QSA,L]

    # Redirect all requests to index.php if file/directory doesn't exist
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?page=$1 [QSA,L]
</IfModule>

# Cache control
<IfModule mod_headers.c>
    # Cache static assets for 1 month
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
    
    # Don't cache HTML files
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
